{
  "expo": {
    "name": "Ma Bible",
    "slug": "ma-bible",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mabible",
    "icon": "./assets/bible.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#2C2C2E",
      "resizeMode": "contain"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/bible.png",
          "color": "#2C2C2E",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bible.png",
        "backgroundColor": "#2C2C2E"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ],
      "package": "com.anonymous.mabible"
    },
    "ios": {
      "icon": "./assets/bible.png",
      "supportsTablet": true
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c233fb59-8c05-4d1f-85f9-6034614fdac4"
      }
    }
  }
}
